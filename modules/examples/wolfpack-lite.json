      "count": 4,
      "visibility": "team",
      "tags": [
        "weapon",
        "slot"
      ]
    }
  ],
  "setup": {
    "phaseId": "briefing",
    "instructions": [
      "Choisir le mode: cooperation contre menace geree par l'hote, ou duel entre deux equipages.",
      "Assigner les postes: capitaine, pilote, machiniste, sonar, torpilles, radio. A moins de six joueurs, fusionner radio avec sonar ou torpilles avec machiniste.",
      "Le capitaine est l'hote technique: il garde le rythme mais ne dispose pas de pouvoirs de MJ illimites.",
      "Initialiser la coque, l'oxygene, les batteries, les torpilles et le bruit selon le scenario choisi.",
      "Placer le sous-marin en mer ouverte et noter la mission: traquer, survivre, intercepter ou s'echapper.",
      "Expliquer aux joueurs que chaque telephone est un poste: les gestes confirment l'action, les boutons restent le secours MVP."
    ],
    "distributions": [
      {
        "id": "initial-station-panel",
        "componentId": "station-panel",
        "target": "allParticipants",
        "count": 1,
        "visibility": "private"
      }
    ]
  },
  "sessionRoles": [
    {
      "id": "host",
      "name": "Hote capitaine",
      "description": "Ouvre la session et garde le rythme, mais reste un membre de l'equipage.",
      "capabilities": [
        "session.host",
        "participants.manage",
        "roles.assign",
        "phase.control"
      ],
      "canInjectGameElements": false,
      "assignableToRoles": [
        "captain"
      ],
      "defaultRoleId": "captain"
    }
  ],
  "phases": [
    {
      "id": "briefing",
      "name": "Briefing",
      "durationSeconds": 180
    },
    {
      "id": "silent-running",
      "name": "Navigation silencieuse",
      "durationSeconds": 600
    },
    {
      "id": "contact",
      "name": "Contact sonar",
      "durationSeconds": 300
    },
    {
      "id": "attack-run",
      "name": "Passe d'attaque",
      "durationSeconds": 240
    },
    {
      "id": "damage-control",
      "name": "Avaries",
      "durationSeconds": 240
    }
  ],
  "roles": [
    {
      "id": "captain",
      "name": "Capitaine",
      "startingResources": {
        "intel": 1
      },
      "responsibilities": [
        "Donner les ordres",
        "Choisir les priorites",
        "Valider tir, plongee d'urgence et rupture de silence"
      ],
      "actions": [
        "issue-order",
        "authorize-fire",
        "emergency-dive"
      ]
    },
    {
      "id": "helmsman",
      "name": "Pilote",
      "startingResources": {},
      "responsibilities": [
        "Maintenir le cap",
        "Changer de profondeur",
        "Executer les manoeuvres"
      ],
      "actions": [
        "change-depth",
        "change-heading",
        "evade"
      ]
    },
    {
      "id": "engineer",
      "name": "Machiniste",
      "startingResources": {},
      "responsibilities": [
        "Gerer batteries, moteurs et reparations",
        "Reduire le bruit",
        "Repartir l'energie"
      ],
      "actions": [
        "repair-system",
        "reroute-power",
        "quiet-engines"
      ]
    },
    {
      "id": "sonar",
      "name": "Operateur sonar",
      "startingResources": {
        "intel": 1
      },
      "responsibilities": [
        "Ecouter les contacts",
        "Interpreter les bruits",
        "Signaler distance et direction probables"
      ],
      "actions": [
        "sonar-sweep",
        "classify-contact",
        "listen-silently"
      ]
    },
    {
      "id": "weapons",
      "name": "Officier torpilles",
      "startingResources": {
        "solution": 0
      },
      "responsibilities": [
        "Armer les torpilles",
        "Calculer une solution de tir",
        "Tirer quand le capitaine autorise"
      ],
      "actions": [
        "load-torpedo",
        "compute-solution",
        "fire-torpedo"
      ]
    },
    {
      "id": "radio",
      "name": "Radio",
      "startingResources": {
        "intel": 1
      },
      "responsibilities": [
        "Recevoir les ordres",
        "Decoder les messages",
        "Risquer une emission radio"
      ],
      "actions": [
        "decode-message",
        "send-burst",
        "intercept"
      ]
    }
  ],
  "mechanics": [
    {
      "id": "crew-command",
      "name": "Coordination d'equipage",
      "family": "coordination",
      "summary": "Un role emet un ordre ou une information qui devient visible a l'equipe selon une politique de visibilite.",
      "phases": [
        "*"
      ],
      "inputs": [
        {
          "id": "actorId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "message",
          "type": "text"
        },
        {
          "id": "visibility",
          "type": "enum",
          "choices": [
            "team",
            "private",
            "dashboard"
          ]
        }
      ],
      "resolution": {
        "type": "broadcastMessage",
        "mode": "immediate"
      },
      "visibility": {
        "dashboard": "full",
        "team": "message-only"
      },
      "variants": [
        {
          "id": "captain-authorization",
          "name": "Autorisation du capitaine",
          "setsStatus": "captainAuthorization"
        },
        {
          "id": "radio-risk",
          "name": "Emission risquee",
          "addsRisk": "enemy-detection"
        },
        {
          "id": "station-report",
          "name": "Compte rendu de poste",
          "visibility": "team"
        },
        {
          "id": "silent-order",
          "name": "Ordre discret",
          "visibility": "private-or-dashboard"
        }
      ]
    },
    {
      "id": "station-action",
      "name": "Action de poste",
      "family": "resource-action",
      "summary": "Un poste depense une ressource, modifie un statut ou produit une information exploitable par l'equipage.",
      "phases": [
        "silent-running",
        "contact",
        "attack-run"
      ],
      "inputs": [
        {
          "id": "actorId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "cost",
          "type": "resource-bundle"
        },
        {
          "id": "payload",
          "type": "structured"
        }
      ],
      "resolution": {
        "type": "applyCostThenEffect",
        "mode": "immediate"
      },
      "visibility": {
        "dashboard": "full",
        "team": "effect-summary",
        "actor": "full"
      },
      "variants": [
        {
          "id": "sensor-check",
          "name": "Detection partielle",
          "effect": "hint"
        },
        {
          "id": "armed-state",
          "name": "Etat arme",
          "effect": "setState"
        },
        {
          "id": "power-routing",
          "name": "Repartition d'energie",
          "effect": "resource-delta"
        },
        {
          "id": "damage-repair",
          "name": "Controle des avaries",
          "effect": "resource-delta"
        },
        {
          "id": "evasion-state",
          "name": "Manoeuvre evasive",
          "effect": "setState"
        }
      ]
    },
    {
      "id": "contested-attack",
      "name": "Attaque contestee",
      "family": "contest",
      "summary": "Une attaque consomme une preparation et se resout contre une defense, une distance ou une evasion.",
      "phases": [
        "attack-run"
      ],
      "inputs": [
        {
          "id": "attackerId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "targetId",
          "type": "participant-or-zone"
        },
        {
          "id": "attackResource",
          "type": "resource-or-status"
        },
        {
          "id": "defenseResource",
          "type": "resource-or-status"
        }
      ],
      "resolution": {
        "type": "opposedCheck",
        "compare": "attack-vs-defense",
        "onTie": "miss-or-facilitatorDecision"
      },
      "visibility": {
        "dashboard": "full",
        "teams": "result-only"
      },
      "variants": [
        {
          "id": "hidden-target",
          "name": "Cible estimee",
          "targetPrecision": "low"
        },
        {
          "id": "simultaneous",
          "name": "Tirs simultanes",
          "ordering": "simultaneous"
        },
        {
          "id": "escort-counterattack",
          "name": "Riposte d'escorte",
          "onMiss": "increaseDamageRisk"
        },
        {
          "id": "duel-fire",
          "name": "Duel de sous-marins",
          "ordering": "phase-or-simultaneous"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "issue-order",
      "name": "Donner un ordre",
      "phase": "*",
      "actor": "captain",
      "target": "team",
