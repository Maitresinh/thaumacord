{
  "id": "long-live-the-king-lite",
  "name": "Long Live the King Lite",
  "version": "0.1.0",
  "timeline": {
    "roundLabel": "Tour",
    "turnCount": 7,
    "durationPolicy": "facilitator-controlled",
    "setupPhaseId": "setup",
    "convergencePhaseId": "audience",
    "decisionPhaseId": "council",
    "notes": "La diplomatie, les cartes, les faveurs et les petitions convergent vers l'audience du roi et la sequence de conseil."
  },
  "players": {
    "min": 4,
    "max": 7
  },
  "resources": [
    { "id": "gold", "name": "Ducats d'or", "visibility": "private", "min": 0 },
    { "id": "favor", "name": "Faveur", "visibility": "private", "min": 0 },
    { "id": "status", "name": "Statut", "visibility": "public", "min": 0 }
  ],
  "phases": [
    { "id": "setup", "name": "Mise en place", "durationSeconds": 300 },
    { "id": "audience", "name": "Audience", "durationSeconds": 180 },
    { "id": "diplomacy", "name": "Diplomatie", "durationSeconds": 900 },
    { "id": "council", "name": "Conseil", "durationSeconds": 420 },
    { "id": "archive", "name": "Archivage", "durationSeconds": 120 }
  ],
  "roles": [
    {
      "id": "queen",
      "name": "Reine",
      "startingResources": { "gold": 5, "favor": 7, "status": 4 },
      "victoryCondition": { "type": "text", "text": "Gagne si elle termine regente et si un joueur a plus de statut que le Tresorier." }
    },
    {
      "id": "baron",
      "name": "Baron",
      "startingResources": { "gold": 3, "favor": 6, "status": 3 },
      "victoryCondition": { "type": "text", "text": "Gagne sans heritier si les 5 cartes de mobilisation sont actives." }
    },
    {
      "id": "treasurer",
      "name": "Tresorier",
      "startingResources": { "gold": 7, "favor": 7, "status": 1 },
      "victoryCondition": { "type": "text", "text": "Gagne avec un heritier et plus de statut que tous les autres joueurs." }
    }
  ],
  "components": [
    { "id": "intrigue-card", "name": "Carte Intrigue", "kind": "card", "count": 80, "visibility": "private", "tags": ["deck", "hand"] },
    { "id": "status-card", "name": "Carte Statut", "kind": "card", "count": 32, "visibility": "private", "tags": ["status", "character"] },
    { "id": "decision-card", "name": "Carte Decision", "kind": "card", "count": 22, "visibility": "facilitator", "tags": ["deck", "petition"] },
    { "id": "health-card", "name": "Carte Sante du roi", "kind": "card", "count": 7, "visibility": "facilitator", "tags": ["deck", "timeline"] },
    { "id": "mobilization-card", "name": "Carte Mobilisation", "kind": "card", "count": 5, "visibility": "public", "tags": ["track"] },
    { "id": "rebellion-card", "name": "Carte Rebellion", "kind": "card", "count": 5, "visibility": "public", "tags": ["track"] }
  ],
  "setup": {
    "phaseId": "setup",
    "instructions": [
      "Assigner les roles et les personnages.",
      "Distribuer les cartes initiales.",
      "Preparer les paquets Decision et Sante du roi.",
      "Verifier les ressources de depart avant la premiere audience."
    ],
    "distributions": [
      { "id": "initial-intrigue", "componentId": "intrigue-card", "target": "allParticipants", "count": 1, "visibility": "private" },
      { "id": "initial-status", "componentId": "status-card", "target": "allParticipants", "count": 1, "visibility": "private" },
      { "id": "queen-status-bonus", "componentId": "status-card", "target": "role", "roleId": "queen", "count": 1, "visibility": "private" }
    ]
  },
  "mechanics": [
    {
      "id": "petition-vote",
      "name": "Petition et vote du conseil",
      "family": "petition",
      "summary": "Un participant depose une demande, les autres votent pour ou contre, puis une autorite ou une table de decision tranche.",
      "phases": ["council"],
      "inputs": [
        { "id": "petitionerId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "petitionText", "type": "text" },
        { "id": "votes", "type": "vote-list", "choices": ["for", "against"] }
      ],
      "resolution": {
        "type": "weightedVoteThenAuthority",
        "weightResource": "favor",
        "fallback": "democraticVote",
        "authority": "king-or-regent"
      },
      "visibility": { "petition": "public", "votes": "public-after-cast", "decision": "public" },
      "variants": [
        { "id": "democratic", "name": "Vote democratique", "weightResource": null },
        { "id": "authority-only", "name": "Decision de l'autorite", "skipVotes": true },
        { "id": "delayed", "name": "Petition reportee", "resolveAtPhase": "next-council" }
      ]
    },
    {
      "id": "direct-gift",
      "name": "Don direct",
      "family": "exchange",
      "summary": "Un participant transfere une ressource a un autre pendant une phase libre.",
      "phases": ["diplomacy"],
      "inputs": [
        { "id": "fromParticipantId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "toParticipantId", "type": "participant" },
        { "id": "resources", "type": "resource-bundle", "allowed": ["gold"] }
      ],
      "resolution": { "type": "exchange", "mode": "immediate" },
      "visibility": { "dashboard": "full", "participants": "involved-only" },
      "variants": [
        { "id": "bribe", "name": "Pot-de-vin lie a un vote", "linksTo": "petition-vote" },
        { "id": "forced-payment", "name": "Paiement force", "requiresRuleTrigger": true }
      ]
    }
  ],
  "actions": [
    {
      "id": "submit-petition",
      "name": "Deposer une petition",
      "phase": "council",
      "actor": "any",
      "target": "game",
      "effect": { "type": "openVote", "weightResource": "favor" },
      "mechanicId": "petition-vote"
    },
    {
      "id": "transfer-gold",
      "name": "Transferer des ducats",
      "phase": "diplomacy",
      "actor": "any",
      "target": "player",
      "effect": { "type": "transferResource", "resource": "gold" },
      "mechanicId": "direct-gift",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    }
  ],
  "zones": [
    {
      "id": "throne-room",
      "name": "Salle du trone",
      "fictionalType": "court",
      "presenceMethod": "manual",
      "effects": [
        { "type": "unlockAction", "action": "submit-petition" }
      ]
    }
  ]
}
