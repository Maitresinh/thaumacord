  "setup": {
    "phaseId": "market",
    "instructions": [
      "Distribuer les roles Putsch et verifier les pseudonymes.",
      "Distribuer les cartes CF, CM, drogue, actions cuivre et bulletins selon les ressources de depart.",
      "Confirmer que Paquito porte la casquette d'autorite si le meneur est aussi directeur des mines."
    ],
    "distributions": [
      { "id": "initial-cf25", "componentId": "cf25-card", "target": "allParticipants", "countResource": "cf25", "visibility": "private" },
      { "id": "initial-cf50", "componentId": "cf50-card", "target": "allParticipants", "countResource": "cf50", "visibility": "private" },
      { "id": "initial-cf100", "componentId": "cf100-card", "target": "allParticipants", "countResource": "cf100", "visibility": "private" },
      { "id": "initial-cm25", "componentId": "cm25-card", "target": "allParticipants", "countResource": "cm25", "visibility": "private" },
      { "id": "initial-cm50", "componentId": "cm50-card", "target": "allParticipants", "countResource": "cm50", "visibility": "private" },
      { "id": "initial-cm100", "componentId": "cm100-card", "target": "allParticipants", "countResource": "cm100", "visibility": "private" },
      { "id": "initial-drug-bags", "componentId": "drug-bag-card", "target": "allParticipants", "countResource": "drugBags", "visibility": "private" },
      { "id": "initial-copper-shares", "componentId": "copper-share-card", "target": "allParticipants", "countResource": "copperShares", "visibility": "private" },
      { "id": "initial-vote-ballots", "componentId": "vote-ballot", "target": "allParticipants", "countResource": "voteBallots", "visibility": "private" }
    ]
  },
  "mechanics": [
    {
      "id": "copper-market",
      "name": "Marche des actions de cuivre",
      "family": "market-economy",
      "summary": "Un participant achete des actions de cuivre au directeur des mines, au cours courant, dans les limites de la phase.",
      "phases": ["market"],
      "inputs": [
        { "id": "buyerId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "quantity", "type": "number", "label": "Actions a acheter" }
      ],
      "resolution": {
        "type": "marketBuy",
        "priceState": "copperPrice",
        "stockState": "sharesAvailableThisHour",
        "limitState": "sharesPerBuyerLimit",
        "sellerRoleId": "facilitator-capitalist",
        "componentId": "copper-share-card"
      },
      "visibility": { "dashboard": "full", "participants": "involved-only" }
    },
    {
      "id": "direct-barter",
      "name": "Transaction directe",
      "family": "exchange",
      "summary": "Deux participants transferent des ressources declarees, avec validation des soldes et visibilite filtree.",
      "phases": ["market", "intrigue"],
      "inputs": [
        { "id": "fromParticipantId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "toParticipantId", "type": "participant" },
        { "id": "resources", "type": "resource-bundle", "allowed": ["money", "weapons", "ammo", "copperShares", "cf25", "cf50", "cf100", "cm25", "cm50", "cm100", "drugBags"] }
      ],
      "resolution": { "type": "exchange", "mode": "immediate" },
      "visibility": { "dashboard": "full", "participants": "involved-only" },
      "variants": [
        { "id": "brokered", "name": "Transaction arbitree", "requiresFacilitator": true },
        { "id": "hidden-price", "name": "Prix cache", "hideResourcesUntilResolved": true }
      ]
    },
    {
      "id": "contested-coup",
      "name": "Coup conteste",
      "family": "contest",
      "summary": "Un attaquant declare une tentative, une cible peut repondre, puis les engagements caches sont reveles et compares.",
      "phases": ["coup", "resolution"],
      "inputs": [
        { "id": "attackerId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "defenderId", "type": "participant" },
        { "id": "leaderIds", "type": "participant-list", "count": 2 },
        { "id": "resources", "type": "resource-bundle", "allowed": ["weapons", "ammo", "influence"] }
      ],
      "resolution": {
        "type": "sealedCommitment",
        "rounds": 1,
        "compare": "highestTotal",
        "onTie": "facilitatorDecision",
        "consumeCommitments": "always",
        "outcomes": [
          {
            "id": "attacker-wins",
            "label": "Attaquant gagne",
            "description": "La tentative de coup reussit.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "attacker-wins" },
              { "type": "scaleSessionCounter", "state": "copperPrice", "factor": 0.5, "rounding": "floor", "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "defender-wins",
            "label": "Defense gagne",
            "description": "La tentative de coup echoue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "defender-wins" },
              { "type": "adjustSessionCounter", "state": "copperPrice", "delta": 1000, "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "tie-facilitator",
            "label": "Egalite MJ",
            "description": "Le MJ tranche une egalite ou une situation ambigue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "tie-facilitator" },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          }
        ]
      },
      "visibility": { "commitments": "hidden-until-reveal", "result": "dashboard-and-involved" },
      "variants": [
        { "id": "open-counter", "name": "Contre public", "commitments": "defender-visible" },
        { "id": "multi-party-coup", "name": "Coup multi-factions", "leaderCount": "2+" }
      ]
    },
    {
      "id": "minister-council-record",
      "name": "Conseil des ministres",
      "family": "live-administration",
      "summary": "Le conseil se tient en direct; l'autorite saisit ensuite les presents, fonds detournes, decisions et ajustements de ressources.",
      "phases": ["first-council"],
      "inputs": [
        { "id": "attendeeIds", "type": "participant-list" },
        { "id": "embezzlement", "type": "resource-bundle", "allowed": ["money"] },
        { "id": "decisions", "type": "text" }
      ],
      "resolution": {
        "type": "liveThenRecord",
        "recordedBy": "facilitator-capitalist",
        "canAdjustResources": ["money"],
        "canSetSessionState": ["firstCouncilDue"],
        "defaultEffects": [
          { "type": "setSessionState", "state": "firstCouncilDue", "value": false }
        ]
      },
      "visibility": { "dashboard": "full", "participants": "public-summary" },
      "variants": [
        { "id": "post-coup", "name": "Conseil apres coup d'Etat", "trigger": "firstCouncilDue" },
        { "id": "regular-hourly", "name": "Conseil regulier", "trigger": "regularCouncilEverySeconds" }
      ]
    },
    {
      "id": "minister-election",
      "name": "Election du conseil",
      "family": "vote",
      "summary": "Chaque joueur depense des bulletins de vote pour designer les conseillers; le tableau cumule les suffrages.",
      "phases": ["first-council"],
      "inputs": [
        { "id": "voterId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "promotionCandidateId", "type": "participant", "label": "Faire entrer au conseil" },
        { "id": "eliminationCandidateId", "type": "participant", "label": "Eliminer du conseil" },
        { "id": "votes", "type": "number", "resource": "voteBallots" }
      ],
      "resolution": { "type": "tally", "state": "ministerElectionTally", "resource": "voteBallots" },
      "visibility": { "dashboard": "full", "participants": "own-vote-and-public-tally" }
    }
  ],
