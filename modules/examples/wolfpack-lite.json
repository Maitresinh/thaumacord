        {
          "type": "unlockPhase",
          "phase": "silent-running"
        }
      ]
    },
    {
      "id": "convoy-route",
      "name": "Route du convoi",
      "fictionalType": "target-zone",
      "presenceMethod": "fictional-map",
      "effects": [
        {
          "type": "unlockPhase",
          "phase": "contact"
        },
        {
          "type": "increaseRisk",
          "risk": "escort-detection",
          "amount": 1
        }
      ]
    },
