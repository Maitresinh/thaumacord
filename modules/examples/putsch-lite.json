{
  "id": "putsch-lite",
  "name": "Putsch Lite",
  "version": "0.1.0",
  "timeline": {
    "regularCouncilEveryTurns": 3,
    "councilAfterCoup": true,
    "councilPhaseId": "first-council"
  },
  "state": {
    "copperPrice": 10,
    "firstCouncilDue": false
  },
  "players": {
    "min": 4,
    "max": 12
  },
  "resources": [
    { "id": "money", "name": "Pesos", "visibility": "private", "min": 0 },
    { "id": "copperShares", "name": "Actions des mines de cuivre", "visibility": "private", "min": 0 },
    { "id": "weapons", "name": "Armes", "visibility": "private", "min": 0 },
    { "id": "ammo", "name": "Munitions", "visibility": "private", "min": 0 },
    { "id": "influence", "name": "Influence", "visibility": "private", "min": 0 }
  ],
  "phases": [
    { "id": "market", "name": "Marche", "durationSeconds": 600 },
    { "id": "intrigue", "name": "Intrigue", "durationSeconds": 900 },
    { "id": "coup", "name": "Coup d'Etat", "durationSeconds": 300 },
    { "id": "resolution", "name": "Resolution", "durationSeconds": 180 },
    { "id": "first-council", "name": "Premier conseil", "durationSeconds": 420 }
  ],
  "roles": [
    {
      "id": "general",
      "name": "General",
      "startingResources": { "money": 8, "weapons": 2, "ammo": 2, "influence": 2 },
      "victoryCondition": { "type": "text", "text": "Gagne par richesse et controle politique en fin de partie." }
    },
    {
      "id": "dealer",
      "name": "Marchand",
      "startingResources": { "money": 12, "weapons": 1, "ammo": 3, "influence": 1 },
      "victoryCondition": { "type": "text", "text": "Gagne par accumulation de richesse et ventes strategiques." }
    },
    {
      "id": "facilitator-capitalist",
      "name": "MJ capitaliste",
      "startingResources": { "money": 20, "copperShares": 6, "weapons": 0, "ammo": 0, "influence": 3 },
      "responsibilities": ["Arbitrer la table", "Gerer les actions des mines de cuivre", "Sieger au premier conseil"],
      "victoryCondition": { "type": "text", "text": "Gagne en terminant avec le plus de pesos." }
    }
  ],
  "mechanics": [
    {
      "id": "direct-barter",
      "name": "Transaction directe",
      "family": "exchange",
      "summary": "Deux participants transferent des ressources declarees, avec validation des soldes et visibilite filtree.",
      "phases": ["market", "intrigue"],
      "inputs": [
        { "id": "fromParticipantId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "toParticipantId", "type": "participant" },
        { "id": "resources", "type": "resource-bundle", "allowed": ["money", "weapons", "ammo"] }
      ],
      "resolution": { "type": "exchange", "mode": "immediate" },
      "visibility": { "dashboard": "full", "participants": "involved-only" },
      "variants": [
        { "id": "brokered", "name": "Transaction arbitree", "requiresFacilitator": true },
        { "id": "hidden-price", "name": "Prix cache", "hideResourcesUntilResolved": true }
      ]
    },
    {
      "id": "contested-coup",
      "name": "Coup conteste",
      "family": "contest",
      "summary": "Un attaquant declare une tentative, une cible peut repondre, puis les engagements caches sont reveles et compares.",
      "phases": ["coup", "resolution"],
      "inputs": [
        { "id": "attackerId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "defenderId", "type": "participant" },
        { "id": "leaderIds", "type": "participant-list", "count": 2 },
        { "id": "resources", "type": "resource-bundle", "allowed": ["weapons", "ammo", "influence"] }
      ],
      "resolution": {
        "type": "sealedCommitment",
        "rounds": 1,
        "compare": "highestTotal",
        "onTie": "facilitatorDecision",
        "consumeCommitments": "always",
        "outcomes": [
          {
            "id": "attacker-wins",
            "label": "Attaquant gagne",
            "description": "La tentative de coup reussit.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "attacker-wins" },
              { "type": "adjustSessionCounter", "state": "copperPrice", "delta": -1, "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "defender-wins",
            "label": "Defense gagne",
            "description": "La tentative de coup echoue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "defender-wins" },
              { "type": "adjustSessionCounter", "state": "copperPrice", "delta": 1, "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "tie-facilitator",
            "label": "Egalite MJ",
            "description": "Le MJ tranche une egalite ou une situation ambigue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "tie-facilitator" },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          }
        ]
      },
      "visibility": { "commitments": "hidden-until-reveal", "result": "dashboard-and-involved" },
      "variants": [
        { "id": "open-counter", "name": "Contre public", "commitments": "defender-visible" },
        { "id": "multi-party-coup", "name": "Coup multi-factions", "leaderCount": "2+" }
      ]
    }
  ],
  "actions": [
    {
      "id": "sell-weapons",
      "name": "Vendre des armes",
      "phase": "market",
      "actor": "any",
      "target": "player",
      "effect": { "type": "transferBundle", "resources": ["money", "weapons"] },
      "mechanicId": "direct-barter",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    },
    {
      "id": "attempt-coup",
      "name": "Tenter un coup d'Etat",
      "phase": "coup",
      "actor": "any",
      "target": "game",
      "effect": { "type": "contestedBid", "resources": ["weapons", "ammo", "influence"] },
      "mechanicId": "contested-coup",
      "gesture": "strike-phone",
      "fallback": "manual-confirmation"
    },
    {
      "id": "embezzle-council-funds",
      "name": "Detourner des fonds du conseil",
      "phase": "first-council",
      "actor": "facilitator-capitalist",
      "target": "self",
      "effect": { "type": "adjustResource", "resource": "money", "delta": 3 },
      "fallback": "facilitator-confirmation"
    }
  ],
  "zones": [
    {
      "id": "black-market",
      "name": "Marche noir",
      "fictionalType": "market",
      "presenceMethod": "qr",
      "effects": [
        { "type": "unlockAction", "action": "sell-weapons" }
      ]
    },
    {
      "id": "palace",
      "name": "Palais presidentiel",
      "fictionalType": "seat-of-power",
      "presenceMethod": "manual",
      "effects": [
        { "type": "unlockAction", "action": "attempt-coup" }
      ]
    }
  ]
}
