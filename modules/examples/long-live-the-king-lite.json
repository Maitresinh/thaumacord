  "mechanics": [
    {
      "id": "petition-vote",
      "name": "Petition et vote du conseil",
      "family": "petition",
      "summary": "Un participant depose une demande, les autres votent pour ou contre, puis une autorite ou une table de decision tranche.",
      "phases": [
        "council"
      ],
      "inputs": [
        {
          "id": "petitionerId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "petitionText",
          "type": "text"
        },
        {
          "id": "votes",
          "type": "vote-list",
          "choices": [
            "for",
            "against"
          ]
        }
      ],
      "resolution": {
        "type": "weightedVoteThenAuthority",
        "weightResource": "favor",
        "fallback": "democraticVote",
        "authority": "king-or-regent"
      },
      "visibility": {
        "petition": "public",
        "votes": "public-after-cast",
        "decision": "public"
      },
      "variants": [
        {
          "id": "democratic",
          "name": "Vote democratique",
          "weightResource": null
        },
        {
          "id": "authority-only",
          "name": "Decision de l'autorite",
          "skipVotes": true
        },
        {
          "id": "delayed",
          "name": "Petition reportee",
          "resolveAtPhase": "next-council"
        }
      ]
    },
    {
      "id": "audience-income",
      "name": "Audience du roi",
      "family": "timed-income",
      "summary": "L'audience se tient en direct; le Roi ou le chambellan enregistre ensuite les revenus, cartes Intrigue, informations de sante et demandes de Faveur.",
      "phases": [
        "audience"
      ],
      "inputs": [
        {
          "id": "turn",
          "type": "session-state",
          "state": "currentTurn"
        },
        {
          "id": "kingHealthy",
          "type": "session-state",
          "state": "kingHealthy"
        }
      ],
      "resolution": {
        "type": "facilitatorDistribution",
        "mode": "guidedInApp",
        "modes": [
          "guidedInApp",
          "liveThenRecord"
        ],
        "recordedBy": "king-or-chamberlain",
        "incomeResource": "gold",
        "intrigueCardsOddTurns": 1,
        "intrigueCardsEvenTurns": 2,
        "queenIntrigueCardsPerTurn": 2,
        "archbishopBonusIntrigueCards": 1,
        "lowStatusIncomeMultiplier": 0.5,
        "skipWhenKingSick": true
      },
      "visibility": {
        "dashboard": "full",
        "participants": "own-income-and-cards"
      },
      "variants": [
        {
          "id": "experienced-table",
          "name": "Sante revelee au tour 1",
          "revealHealthOnTurnOne": true
        }
      ]
    },
    {
      "id": "health-mobilization-rebellion",
      "name": "Sante, mobilisation et rebellion",
      "family": "track",
      "summary": "Le Roi suit la sante, les cartes de mobilisation du Baron et les cartes de rebellion activees par l'Ambassadeur.",
      "phases": [
        "audience",
        "council"
      ],
      "inputs": [
        {
          "id": "activeHealthCards",
          "type": "session-state"
        },
        {
          "id": "activeMobilization",
          "type": "session-counter"
        },
        {
          "id": "activeRebellion",
          "type": "session-counter"
        }
      ],
      "resolution": {
        "type": "publicTracks",
        "healthCardsTotal": 10,
        "healthCardsInLine": 6,
        "mobilizationCards": 5,
        "rebellionCards": 5,
        "lastCouncilKingReturns": true
      },
      "visibility": {
        "dashboard": "full",
        "participants": "public-tracks"
      },
      "variants": [
        {
          "id": "baron-suppresses-rebellion",
          "name": "Mobilisation contre rebellion",
          "trigger": "accepted-mobilization-petition"
        }
      ]
    },
    {
      "id": "direct-gift",
      "name": "Don direct",
      "family": "exchange",
      "summary": "Un participant transfere une ressource a un autre pendant une phase libre.",
      "phases": [
        "diplomacy"
      ],
      "inputs": [
        {
          "id": "fromParticipantId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "toParticipantId",
          "type": "participant"
        },
        {
          "id": "resources",
          "type": "resource-bundle",
          "allowed": [
            "gold"
          ]
        }
      ],
      "resolution": {
        "type": "exchange",
        "mode": "immediate"
      },
      "visibility": {
        "dashboard": "full",
        "participants": "involved-only"
      },
      "variants": [
        {
          "id": "bribe",
          "name": "Pot-de-vin lie a un vote",
          "linksTo": "petition-vote"
        },
        {
          "id": "forced-payment",
          "name": "Paiement force",
          "requiresRuleTrigger": true
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "submit-petition",
      "name": "Deposer une petition",
      "phase": "council",
      "actor": "any",
      "target": "game",
      "effect": {
        "type": "openVote",
        "weightResource": "favor"
      },
      "mechanicId": "petition-vote"
    },
    {
      "id": "vote-petition",
      "name": "Engager de la faveur sur une petition",
      "phase": "council",
      "actor": "any",
      "target": "game",
      "effect": {
        "type": "castPetitionVote",
        "resource": "favor",
        "resolutionMechanicId": "petition-vote",
        "choices": [
          "for",
          "against"
        ],
        "voteState": "petitionVotes"
      },
      "mechanicId": "petition-vote",
      "gesture": "ballot-drop",
      "fallback": "manual-confirmation"
    },
    {
      "id": "resolve-petition",
      "name": "Trancher la petition",
      "phase": "council",
      "actor": "king",
      "target": "game",
      "effect": {
        "type": "resolvePetition",
        "resolutionMechanicId": "petition-vote",
        "allowedOutcomes": [
          "accepted",
          "rejected",
          "deferred"
        ],
        "resultState": "lastPetitionResult"
      },
      "mechanicId": "petition-vote",
      "fallback": "facilitator-confirmation"
    },
    {
      "id": "hold-audience",
      "name": "Tenir l'audience",
      "phase": "audience",
      "actor": "king",
      "target": "game",
      "effect": {
        "type": "runTimedIncome",
        "resource": "gold",
        "amountResource": "income",
        "componentId": "intrigue-card",
        "oddTurnCount": 1,
        "evenTurnCount": 2,
        "fixedDrawByRole": {
          "queen": 2
        },
        "bonusDrawByRole": {
          "archbishop": 1
        },
        "lowStatusResource": "status",
        "lowStatusThreshold": 2,
        "lowStatusIncomeMultiplier": 0.5,
        "excludeRoles": [
          "king"
        ]
      },
      "mechanicId": "audience-income",
      "fallback": "facilitator-confirmation"
    },
    {
      "id": "transfer-gold",
      "name": "Transferer des ducats",
      "phase": "diplomacy",
      "actor": "any",
      "target": "player",
      "effect": {
        "type": "transferResource",
        "resource": "gold"
      },
      "mechanicId": "direct-gift",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    }
  ],
  "zones": [
    {
      "id": "throne-room",
      "name": "Salle du trone",
      "fictionalType": "court",
      "presenceMethod": "manual",
      "effects": [
        {
          "type": "unlockAction",
          "action": "submit-petition"
        }
      ]
    }
  ],
  "rules": {
    "summary": "Long Live the King est un jeu de cour en tours. Tout converge vers les audiences et conseils ou le Roi, le chambellan ou l autorite de table enregistrent les revenus, petitions, votes de faveur et decisions royales.",
    "sections": [
      {
        "id": "goal",
        "title": "But du jeu",
        "audience": "all",
        "body": "Chaque personnage cherche a accumuler influence, or, statut ou avantages politiques selon son role.",
        "bullets": [
          "Le Roi dirige la table mais reste soumis aux intrigues.",
          "Les autres personnages negocient, demandent des faveurs et influencent les petitions.",
          "La victoire depend du scenario et des objectifs de personnage importes."
        ]
      },
      {
        "id": "turns",
        "title": "Tour et phases",
        "audience": "all",
        "body": "Un tour type suit Audience, Diplomatie, Conseil.",
        "bullets": [
          "Audience: revenus et cartes/informations sont distribues.",
          "Diplomatie: les joueurs negocient librement et transferent des ducats.",
          "Conseil: petitions, votes de faveur et decisions sont resolus.",
          "Le dernier conseil ne doit pas etre saute."
        ]
      },
      {
        "id": "audience",
        "title": "Audience",
        "audience": "all",
        "body": "L audience peut se tenir oralement a table ou etre guidee par l app.",
        "bullets": [
          "Le Roi ou le chambellan lance l audience.",
          "L app applique les revenus et tirages prevus.",
          "Les informations de sante, mobilisation ou rebellion sont enregistrees selon le module.",
          "Les demandes non resolues peuvent etre portees au conseil."
        ]
      },
      {
        "id": "petitions",
        "title": "Petitions et faveur",
        "audience": "all",
        "body": "Une petition ouvre une decision collective ou royale.",
        "bullets": [
          "Un joueur depose une petition pendant la phase autorisee.",
          "Les joueurs engagent de la faveur pour soutenir ou s opposer.",
          "Le Roi ou l autorite tranche: acceptee, rejetee ou reportee.",
          "Les pots-de-vin et transferts restent des echanges entre joueurs."
        ]
      },
      {
        "id": "player-info",
        "title": "Ce que voit un joueur",
        "audience": "participants",
        "body": "Le telephone affiche son personnage, ses ressources, les actions disponibles et les messages qui le concernent.",
        "bullets": [
          "Les informations cachees des autres personnages ne sont pas visibles.",
          "Les votes et transferts n apparaissent que selon leur visibilite.",
          "L onglet Personnage resume le role courant."
        ]
      }
    ]
  }
}
