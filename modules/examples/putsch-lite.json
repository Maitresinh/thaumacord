    { "id": "cm25-card", "name": "Carte 25 caisses de munitions", "kind": "resource-card", "count": 30, "visibility": "private", "tags": ["ammo", "putsch"] },
    { "id": "cm50-card", "name": "Carte 50 caisses de munitions", "kind": "resource-card", "count": 10, "visibility": "private", "tags": ["ammo", "putsch"] },
