  "mechanics": [
    {
      "id": "copper-market",
      "name": "Marche des actions de cuivre",
      "family": "market-economy",
      "summary": "Un participant achete des actions de cuivre au directeur des mines, au cours courant, dans les limites de la phase.",
      "phases": [
        "market"
      ],
      "inputs": [
        {
          "id": "buyerId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "quantity",
          "type": "number",
          "label": "Actions a acheter"
        }
      ],
      "resolution": {
        "type": "marketBuy",
        "priceState": "copperPrice",
        "stockState": "sharesAvailableThisHour",
        "limitState": "sharesPerBuyerLimit",
        "sellerRoleId": "facilitator-capitalist",
        "componentId": "copper-share-card"
      },
      "visibility": {
        "dashboard": "full",
        "participants": "involved-only"
      }
    },
    {
      "id": "direct-barter",
      "name": "Transaction directe",
      "family": "exchange",
      "summary": "Deux participants transferent des ressources declarees, avec validation des soldes et visibilite filtree.",
      "phases": [
        "market",
        "intrigue"
      ],
      "inputs": [
        {
          "id": "fromParticipantId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "toParticipantId",
          "type": "participant"
        },
        {
          "id": "resources",
          "type": "resource-bundle",
          "allowed": [
            "money",
            "weapons",
            "ammo",
            "copperShares",
            "cf25",
            "cf50",
            "cf100",
            "cm25",
            "cm50",
            "cm100",
            "drugBags"
          ]
        }
      ],
      "resolution": {
        "type": "exchange",
        "mode": "immediate"
      },
      "visibility": {
        "dashboard": "full",
        "participants": "involved-only"
      },
      "variants": [
        {
          "id": "brokered",
          "name": "Transaction arbitree",
          "requiresFacilitator": true
        },
        {
          "id": "hidden-price",
          "name": "Prix cache",
          "hideResourcesUntilResolved": true
        }
      ]
    },
    {
      "id": "contested-coup",
      "name": "Coup conteste",
      "family": "contest",
      "summary": "Un attaquant declare une tentative, une cible peut repondre, puis les engagements caches sont reveles et compares.",
      "phases": [
        "coup",
        "resolution"
      ],
      "inputs": [
        {
          "id": "attackerId",
          "type": "participant",
          "source": "actor-or-bound-device"
        },
        {
          "id": "defenderId",
          "type": "participant"
        },
        {
          "id": "leaderIds",
          "type": "participant-list",
          "count": 2
        },
        {
          "id": "resources",
          "type": "resource-bundle",
          "allowed": [
            "weapons",
            "ammo",
            "influence"
          ]
        }
      ],
      "resolution": {
        "type": "sealedCommitment",
        "rounds": 1,
        "compare": "highestTotal",
        "onTie": "facilitatorDecision",
        "consumeCommitments": "always",
        "outcomes": [
          {
            "id": "attacker-wins",
            "label": "Attaquant gagne",
            "description": "La tentative de coup reussit.",
            "effects": [
              {
                "type": "setState",
                "state": "coupOutcome",
                "value": "attacker-wins"
              },
              {
                "type": "scaleSessionCounter",
                "state": "copperPrice",
                "factor": 0.5,
                "rounding": "floor",
                "min": 1
              },
              {
                "type": "setSessionState",
                "state": "firstCouncilDue",
                "value": true
              }
            ]
          },
          {
            "id": "defender-wins",
            "label": "Defense gagne",
            "description": "La tentative de coup echoue.",
            "effects": [
              {
                "type": "setState",
                "state": "coupOutcome",
                "value": "defender-wins"
              },
              {
                "type": "adjustSessionCounter",
                "state": "copperPrice",
                "delta": 1000,
                "min": 1
              },
              {
                "type": "setSessionState",
                "state": "firstCouncilDue",
                "value": true
              }
            ]
          },
          {
            "id": "tie-facilitator",
            "label": "Egalite MJ",
            "description": "Le MJ tranche une egalite ou une situation ambigue.",
            "effects": [
              {
                "type": "setState",
                "state": "coupOutcome",
                "value": "tie-facilitator"
              },
              {
                "type": "setSessionState",
                "state": "firstCouncilDue",
                "value": true
              }
            ]
          }
        ]
      },
      "visibility": {
        "commitments": "hidden-until-reveal",
        "result": "dashboard-and-involved"
      },
      "variants": [
        {
          "id": "open-counter",
          "name": "Contre public",
          "commitments": "defender-visible"
        },
        {
          "id": "multi-party-coup",
          "name": "Coup multi-factions",
          "leaderCount": "2+"
        }
      ]
    },
    {
      "id": "minister-council-record",
      "name": "Conseil des ministres",
      "family": "live-administration",
      "summary": "Le conseil se tient en direct; l'autorite saisit ensuite les presents, fonds detournes, decisions et ajustements de ressources.",
      "phases": [
        "first-council"
      ],
      "inputs": [
        {
          "id": "attendeeIds",
          "type": "participant-list"
        },
        {
          "id": "embezzlement",
          "type": "resource-bundle",
          "allowed": [
            "money"
          ]
        },
        {
          "id": "decisions",
          "type": "text"
        }
      ],
      "resolution": {
        "type": "liveThenRecord",
        "recordedBy": "facilitator-capitalist",
        "canAdjustResources": [
          "money"
        ],
        "canSetSessionState": [
          "firstCouncilDue"
        ],
        "defaultEffects": [
          {
            "type": "setSessionState",
            "state": "firstCouncilDue",
            "value": false
          }
        ]
      },
      "visibility": {
        "dashboard": "full",
        "participants": "public-summary"
      },
      "variants": [
        {
          "id": "post-coup",
          "name": "Conseil apres coup d'Etat",
          "trigger": "firstCouncilDue"
        },
        {
          "id": "regular-hourly",
          "name": "Conseil regulier",
          "trigger": "regularCouncilEverySeconds"
        }
      ]
    },
