{
  "id": "wolfpack-lite",
  "name": "Wolfpack",
  "version": "0.1.0",
  "pitch": "Un equipage de sous-marin pendant la Seconde Guerre mondiale coordonne navigation, machines, sonar, armement et commandement pour traquer ou fuir un ennemi.",
  "inspirationNotes": "Module original pour Ludovive, inspire des jeux d'equipage coordonne en temps reel comme Captain Sonar de Roberto Fraga et Yohan Lemonnier, sans reprendre leurs regles.",
  "uiTheme": {
    "template": "submarine-stations",
    "tone": "Acier, cadrans, lumiere rouge, cartes marines, messages courts et pression d'equipage.",
    "colors": {
      "background": "#0b1114",
      "panel": "#172025",
      "ink": "#e9f0e6",
      "muted": "#9fb0aa",
      "accent": "#b64035",
      "secondary": "#2f6a78",
      "success": "#4f7b56",
      "warning": "#c69a3d"
    },
    "icons": {
      "game": "icon:submarine",
      "coordination": "icon:radio",
      "resource-action": "icon:gauge",
      "contest": "icon:torpedo",
      "hull": "icon:hull",
      "oxygen": "icon:oxygen",
      "battery": "icon:battery",
      "noise": "icon:sonar",
      "torpedoes": "icon:torpedo",
      "solution": "icon:crosshair",
      "intel": "icon:radio"
    },
    "interactionLabels": {
      "primary": "Geste de poste",
      "fallback": "Controle de bord"
    },
    "fonts": {
      "display": "'Arial Narrow', 'Bahnschrift Condensed', 'Segoe UI', sans-serif",
      "body": "Bahnschrift, 'Segoe UI', Arial, sans-serif",
      "numeric": "Consolas, 'Courier New', monospace"
    }
  },
  "soundboard": [
    {
      "id": "briefing-bell",
      "name": "Briefing equipage",
      "channel": "stinger",
      "phase": "briefing",
      "tone": "cloche courte et murmure de salle des cartes",
      "visibility": "all",
      "url": "sound:briefing-bell"
    },
    {
      "id": "silent-running",
      "name": "Silence machine",
      "channel": "event",
      "phase": "silent-running",
      "tone": "moteurs etouffes, metal sous pression",
      "visibility": "all",
      "url": "sound:silent-running"
    },
    {
      "id": "sonar-contact",
      "name": "Contact sonar",
      "channel": "alert",
      "phase": "contact",
      "tone": "ping sonar isole puis silence",
      "visibility": "all",
      "url": "sound:sonar-contact"
    },
    {
      "id": "attack-alarm",
      "name": "Postes de combat",
      "channel": "alert",
      "phase": "attack-run",
      "tone": "alarme rouge et ordre bref",
      "visibility": "all",
      "url": "sound:attack-alarm"
    },
    {
      "id": "damage-control",
      "name": "Equipe avaries",
      "channel": "alert",
      "phase": "damage-control",
      "tone": "fuite, outils, metal qui craque",
      "visibility": "all",
      "url": "sound:damage-control"
    }
  ],
  "state": {
    "missionMode": "cooperative-hunt",
    "depth": "periscope-depth",
    "heading": "north-east",
    "enemyRange": "unknown",
    "enemyBearing": "unknown",
    "contactQuality": "none",
    "captainAuthorization": false,
    "torpedoLoaded": false,
    "evasion": "none",
    "missionClock": 0,
    "playtestNotes": {
      "cooperative": "Un seul equipage traque un convoi ou un sous-marin ennemi gere par l'hote.",
      "duel": "Deux equipages peuvent jouer en miroir; chaque equipe garde ses postes et son dashboard filtre.",
      "liveAdaptation": "Les telephones representent les postes: le geste donne le ton, l'app enregistre l'ordre, le cout et l'effet."
