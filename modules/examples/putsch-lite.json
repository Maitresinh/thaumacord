{
  "id": "putsch-lite",
  "name": "Putsch Lite",
  "version": "0.1.0",
  "timeline": {
    "regularCouncilEverySeconds": 3600,
    "councilAfterCoup": true,
    "councilPhaseId": "first-council",
    "copperPriceIncreasePerHour": 1000
  },
  "state": {
    "copperPrice": 1000,
    "firstCouncilDue": false,
    "sharesAvailableThisHour": 20,
    "sharesPerBuyerLimit": 5,
    "directorSharesForSalePerHour": 6
  },
  "players": {
    "min": 4,
    "max": 12
  },
  "resources": [
    { "id": "money", "name": "Escudos", "visibility": "private", "min": 0 },
    { "id": "copperShares", "name": "Actions des mines de cuivre", "visibility": "private", "min": 0 },
    { "id": "weapons", "name": "Armes", "visibility": "private", "min": 0 },
    { "id": "ammo", "name": "Munitions", "visibility": "private", "min": 0 },
    { "id": "influence", "name": "Influence", "visibility": "private", "min": 0 },
    { "id": "cf25", "name": "25 caisses de fusils", "visibility": "private", "min": 0 },
    { "id": "cf50", "name": "50 caisses de fusils", "visibility": "private", "min": 0 },
    { "id": "cf100", "name": "100 caisses de fusils", "visibility": "private", "min": 0 },
    { "id": "cm25", "name": "25 caisses de munitions", "visibility": "private", "min": 0 },
    { "id": "cm50", "name": "50 caisses de munitions", "visibility": "private", "min": 0 },
    { "id": "cm100", "name": "100 caisses de munitions", "visibility": "private", "min": 0 },
    { "id": "drugBags", "name": "Sacs de drogue", "visibility": "private", "min": 0 },
    { "id": "voteBallots", "name": "Bulletins de vote", "visibility": "private", "min": 0 }
  ],
  "sessionRoles": [
    {
      "id": "host",
      "name": "Hote technique",
      "description": "Ouvre la session, accueille les appareils, assigne les roles et garde le rythme de table.",
      "capabilities": ["session.host", "participants.manage", "roles.assign", "phase.control"],
      "canInjectGameElements": false,
      "optional": false,
      "modes": ["separate", "combined-with-game-authority"]
    },
    {
      "id": "game-authority",
      "name": "Autorite d'injection",
      "description": "Peut introduire, corriger ou arbitrer des elements de jeu sans les limites normales des joueurs.",
      "capabilities": ["resources.adjust", "state.adjust", "components.draw", "messages.send", "resolutions.override"],
      "canInjectGameElements": true,
      "optional": true,
      "assignableToRoles": ["facilitator-capitalist"],
      "defaultRoleId": "facilitator-capitalist",
      "modes": ["hote-et-directeur", "hote-separe-directeur-joueur"]
    }
  ],
  "phases": [
    { "id": "market", "name": "Marche", "durationSeconds": 600 },
    { "id": "intrigue", "name": "Intrigue", "durationSeconds": 900 },
    { "id": "coup", "name": "Coup d'Etat", "durationSeconds": 300 },
    { "id": "resolution", "name": "Resolution", "durationSeconds": 180 },
    { "id": "first-council", "name": "Premier conseil", "durationSeconds": 420 }
  ],
  "roles": [
    {
      "id": "general",
      "name": "General",
      "startingResources": { "money": 8, "weapons": 2, "ammo": 2, "influence": 2 },
      "victoryCondition": { "type": "text", "text": "Gagne par richesse et controle politique en fin de partie." }
    },
    {
      "id": "dealer",
      "name": "Marchand",
      "startingResources": { "money": 12, "weapons": 1, "ammo": 3, "influence": 1 },
      "victoryCondition": { "type": "text", "text": "Gagne par accumulation de richesse et ventes strategiques." }
    },
    {
      "id": "facilitator-capitalist",
      "name": "Paquito Borrachon",
      "officialRole": "President des mines de cuivre d'Alcabal et meneur de jeu.",
      "secretRole": "Aucun role secret.",
      "startingResources": { "money": 0, "copperShares": 50, "weapons": 0, "ammo": 0, "influence": 3 },
      "responsibilities": ["Arbitrer la table", "Gerer les actions des mines de cuivre", "Sieger au premier conseil si elu"],
      "victoryCondition": { "type": "text", "text": "Gagne en terminant avec le plus d'escudos; les actions restantes valent la moitie du cours." }
    },
    {
      "id": "kgb-agent",
      "name": "James Stones",
      "officialRole": "Negociant en matieres premieres, notamment cuivre.",
      "secretRole": "Agent du KGB; vendre des armes aux deux forces armees.",
      "startingResources": { "money": 20000, "cf50": 2, "cf25": 2, "cm100": 1, "cm25": 2, "cm50": 1, "voteBallots": 8 },
      "victoryCondition": { "type": "text", "text": "Accumuler des escudos par le commerce et l'influence politique." }
    },
    {
      "id": "cia-agent",
      "name": "Giani Forlano",
      "officialRole": "Marchand de bananes.",
      "secretRole": "Agent de la CIA; vendre des armes aux deux forces armees.",
      "startingResources": { "money": 20000, "cf100": 2, "cf25": 2, "cm100": 1, "cm50": 2, "voteBallots": 8 },
      "victoryCondition": { "type": "text", "text": "Accumuler des escudos par le commerce et l'influence politique." }
    },
    {
      "id": "drug-trafficker",
      "name": "Vladimir Doukorof",
      "officialRole": "Marchand de fusils de chasse.",
      "secretRole": "Trafiquant de drogue; ecouler le plus possible de sacs de drogue.",
      "startingResources": { "money": 15000, "drugBags": 5, "cm25": 1, "voteBallots": 8 },
      "victoryCondition": { "type": "text", "text": "Transformer la drogue et les arrangements en escudos." }
    },
    {
      "id": "fun-agent",
      "name": "Raul Belgrano",
      "officialRole": "Specialiste des reserves de chasse.",
      "secretRole": "Representant du FUN, au pouvoir au debut de partie.",
      "startingResources": { "money": 15000, "cf50": 1, "cf25": 2, "cm50": 1, "cm25": 1, "drugBags": 1, "voteBallots": 8 },
      "victoryCondition": { "type": "text", "text": "Conserver ou reprendre le pouvoir; le camp au pouvoir en fin de partie double son total." }
    },
    {
      "id": "gag-agent",
      "name": "Miltos Agripnakis",
      "officialRole": "Proprietaire terrien.",
      "secretRole": "Agent des forces armees du GAG, dans l'opposition au debut.",
      "startingResources": { "money": 15000, "cf100": 1, "cf25": 1, "cm50": 1, "cm25": 2, "voteBallots": 8 },
      "victoryCondition": { "type": "text", "text": "Prendre puis conserver le pouvoir; le camp au pouvoir en fin de partie double son total." }
    }
  ],
  "mechanics": [
    {
      "id": "direct-barter",
      "name": "Transaction directe",
      "family": "exchange",
      "summary": "Deux participants transferent des ressources declarees, avec validation des soldes et visibilite filtree.",
      "phases": ["market", "intrigue"],
      "inputs": [
        { "id": "fromParticipantId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "toParticipantId", "type": "participant" },
        { "id": "resources", "type": "resource-bundle", "allowed": ["money", "weapons", "ammo", "copperShares", "cf25", "cf50", "cf100", "cm25", "cm50", "cm100", "drugBags"] }
      ],
      "resolution": { "type": "exchange", "mode": "immediate" },
      "visibility": { "dashboard": "full", "participants": "involved-only" },
      "variants": [
        { "id": "brokered", "name": "Transaction arbitree", "requiresFacilitator": true },
        { "id": "hidden-price", "name": "Prix cache", "hideResourcesUntilResolved": true }
      ]
    },
    {
      "id": "contested-coup",
      "name": "Coup conteste",
      "family": "contest",
      "summary": "Un attaquant declare une tentative, une cible peut repondre, puis les engagements caches sont reveles et compares.",
      "phases": ["coup", "resolution"],
      "inputs": [
        { "id": "attackerId", "type": "participant", "source": "actor-or-bound-device" },
        { "id": "defenderId", "type": "participant" },
        { "id": "leaderIds", "type": "participant-list", "count": 2 },
        { "id": "resources", "type": "resource-bundle", "allowed": ["weapons", "ammo", "influence"] }
      ],
      "resolution": {
        "type": "sealedCommitment",
        "rounds": 1,
        "compare": "highestTotal",
        "onTie": "facilitatorDecision",
        "consumeCommitments": "always",
        "outcomes": [
          {
            "id": "attacker-wins",
            "label": "Attaquant gagne",
            "description": "La tentative de coup reussit.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "attacker-wins" },
              { "type": "scaleSessionCounter", "state": "copperPrice", "factor": 0.5, "rounding": "floor", "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "defender-wins",
            "label": "Defense gagne",
            "description": "La tentative de coup echoue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "defender-wins" },
              { "type": "adjustSessionCounter", "state": "copperPrice", "delta": 1000, "min": 1 },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          },
          {
            "id": "tie-facilitator",
            "label": "Egalite MJ",
            "description": "Le MJ tranche une egalite ou une situation ambigue.",
            "effects": [
              { "type": "setState", "state": "coupOutcome", "value": "tie-facilitator" },
              { "type": "setSessionState", "state": "firstCouncilDue", "value": true }
            ]
          }
        ]
      },
      "visibility": { "commitments": "hidden-until-reveal", "result": "dashboard-and-involved" },
      "variants": [
        { "id": "open-counter", "name": "Contre public", "commitments": "defender-visible" },
        { "id": "multi-party-coup", "name": "Coup multi-factions", "leaderCount": "2+" }
      ]
    },
    {
      "id": "minister-council-record",
      "name": "Conseil des ministres",
      "family": "live-administration",
      "summary": "Le conseil se tient en direct; l'autorite saisit ensuite les presents, fonds detournes, decisions et ajustements de ressources.",
      "phases": ["first-council"],
      "inputs": [
        { "id": "attendeeIds", "type": "participant-list" },
        { "id": "embezzlement", "type": "resource-bundle", "allowed": ["money"] },
        { "id": "decisions", "type": "text" }
      ],
      "resolution": {
        "type": "liveThenRecord",
        "recordedBy": "facilitator-capitalist",
        "canAdjustResources": ["money"],
        "canSetSessionState": ["firstCouncilDue"],
        "defaultEffects": [
          { "type": "setSessionState", "state": "firstCouncilDue", "value": false }
        ]
      },
      "visibility": { "dashboard": "full", "participants": "public-summary" },
      "variants": [
        { "id": "post-coup", "name": "Conseil apres coup d'Etat", "trigger": "firstCouncilDue" },
        { "id": "regular-hourly", "name": "Conseil regulier", "trigger": "regularCouncilEverySeconds" }
      ]
    }
  ],
  "actions": [
    {
      "id": "sell-weapons",
      "name": "Vendre des armes",
      "phase": "market",
      "actor": "any",
      "target": "player",
      "effect": { "type": "transferBundle", "resources": ["money", "weapons"] },
      "mechanicId": "direct-barter",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    },
    {
      "id": "trade-copper-shares",
      "name": "Acheter ou vendre des actions de cuivre",
      "phase": "market",
      "actor": "any",
      "target": "player",
      "effect": { "type": "transferBundle", "resources": ["money", "copperShares"] },
      "mechanicId": "direct-barter",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    },
    {
      "id": "trade-arms-caches",
      "name": "Vendre fusils ou munitions",
      "phase": "market",
      "actor": "any",
      "target": "player",
      "effect": { "type": "transferBundle", "resources": ["money", "cf25", "cf50", "cf100", "cm25", "cm50", "cm100"] },
      "mechanicId": "direct-barter",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    },
    {
      "id": "sell-drugs",
      "name": "Ecouler de la drogue",
      "phase": "intrigue",
      "actor": "drug-trafficker",
      "target": "player",
      "effect": { "type": "transferBundle", "resources": ["money", "drugBags"] },
      "mechanicId": "direct-barter",
      "gesture": "touch-phones",
      "fallback": "manual-confirmation"
    },
    {
      "id": "attempt-coup",
      "name": "Tenter un coup d'Etat",
      "phase": "coup",
      "actor": "any",
      "target": "game",
      "effect": { "type": "contestedBid", "resources": ["weapons", "ammo", "influence"] },
      "mechanicId": "contested-coup",
      "gesture": "strike-phone",
      "fallback": "manual-confirmation"
    },
    {
      "id": "embezzle-council-funds",
      "name": "Detourner des fonds du conseil",
      "phase": "first-council",
      "actor": "facilitator-capitalist",
      "target": "self",
      "effect": { "type": "adjustResource", "resource": "money", "delta": 5000 },
      "fallback": "facilitator-confirmation"
    },
    {
      "id": "record-minister-council",
      "name": "Enregistrer le conseil",
      "phase": "first-council",
      "actor": "facilitator-capitalist",
      "target": "game",
      "effect": { "type": "recordLiveResults" },
      "mechanicId": "minister-council-record",
      "fallback": "facilitator-confirmation"
    }
  ],
  "zones": [
    {
      "id": "black-market",
      "name": "Marche noir",
      "fictionalType": "market",
      "presenceMethod": "qr",
      "effects": [
        { "type": "unlockAction", "action": "sell-weapons" }
      ]
    },
    {
      "id": "palace",
      "name": "Palais presidentiel",
      "fictionalType": "seat-of-power",
      "presenceMethod": "manual",
      "effects": [
        { "type": "unlockAction", "action": "attempt-coup" }
      ]
    }
  ]
}
