      "victoryCondition": { "type": "text", "text": "Conserver ou reprendre le pouvoir; le camp au pouvoir en fin de partie double son total." }
    },
    {
      "id": "gag-agent",
      "name": "Miltos Agripnakis",
      "officialRole": "Proprietaire terrien.",
      "secretRole": "Agent des forces armees du GAG, dans l'opposition au debut.",
